# Local dev: copy to .env.local (gitignored). Production: define the same names in
# Vercel → Project → Settings → Environment Variables (never commit real secrets).

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
# Also accepted as x-telemetry-secret header or ?telemetry_secret= on POST (avoid query if possible).
TELEMETRY_SECRET=long-random-string-for-arduino-bridge
OPENAI_API_KEY=

# Vercel Cron (set CRON_SECRET in Vercel project env; same value secures cron routes)
CRON_SECRET=long-random-cron-secret

# Expo Push API (Expo dashboard → Access Token)
EXPO_ACCESS_TOKEN=

# Optional: Arduino IoT Cloud API client (server-side automation apply route)
ARDUINO_CLIENT_ID=
ARDUINO_CLIENT_SECRET=

# Optional: public URL of your Lexis dashboard (second Vercel project). Shown as a link on the API home page.
LEXIS_DASHBOARD_URL=
