EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local API: use http://localhost:3001. For Expo Go on a phone, prefer HTTPS API (e.g. Vercel) or LAN IP + Android; iOS often blocks http:// LAN.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Optional: Expo push (Expo Go). UUID from https://expo.dev → Project → Project settings → Project ID. Or run `eas init` in this folder (writes app.json). Restart Metro after setting.
EXPO_PUBLIC_EAS_PROJECT_ID=
