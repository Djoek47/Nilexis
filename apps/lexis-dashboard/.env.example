# Same Supabase project as mobile — anon key is safe in the browser (RLS enforced).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Nelexis API (deploy services/api on Vercel); used for JWT-authenticated routes from the dashboard when wired.
NEXT_PUBLIC_NELEXIS_API_URL=https://your-nelexis-api.vercel.app
